{
  "manifest_version": 3,
  "name": "ChatGPT Persona Project Harvester",
  "version": "1.0.0",
  "description": "Creates a ChatGPT Project per batch (Project-only memory), runs the batch's prompts across project chats, then moves to the next persona.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ChatGPT Persona Project Harvester"
  }
}
